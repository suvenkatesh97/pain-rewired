---
import Base from '../layouts/Base.astro';

const terms = [
  { term: "Allodynia", def: "Pain from something that shouldn't hurt — like light touch, clothing, or a hug." },
  { term: "Central Sensitization", def: "A process where the central nervous system becomes hypersensitive, amplifying pain signals beyond what's normal." },
  { term: "Central Sensitization Syndromes", def: "A group of overlapping conditions (fibromyalgia, IBS, TMJ, etc.) that share central sensitization as a mechanism." },
  { term: "EAET", def: "Emotional Awareness and Expression Therapy. A treatment that helps process emotions contributing to pain." },
  { term: "fMRI", def: "Functional MRI — a brain scan that shows which brain regions are active during pain." },
  { term: "Graded Exposure", def: "Gradually and safely reintroducing activities your brain has learned to fear, to retrain safety signals." },
  { term: "Hyperalgesia", def: "When things that should hurt a little hurt a lot — the pain volume is turned way up." },
  { term: "IASP", def: "International Association for the Study of Pain. The global authority on pain classification." },
  { term: "Nociception", def: "The neural process of detecting actual or potential tissue damage. Not the same as pain — pain is the brain's interpretation." },
  { term: "Nociceptive Pain", def: "Normal pain from tissue damage — like a cut, burn, or broken bone. The alarm system working correctly." },
  { term: "Nociplastic Pain", def: "The formal clinical term for pain from altered nociception without clear tissue damage. The IASP's third pain category alongside nociceptive and neuropathic." },
  { term: "Neuropathic Pain", def: "Pain caused by damage to nerves themselves — like diabetic neuropathy or sciatica." },
  { term: "Neuroplastic Pain", def: "Chronic pain caused by changes in neural pathways rather than ongoing tissue damage. Interchangeable with nociplastic pain." },
  { term: "Neuroplasticity", def: "The brain's ability to change and reorganize itself by forming new neural connections. Works both ways — can learn pain and unlearn it." },
  { term: "Pain Catastrophizing", def: "A pattern of imagining the worst about pain. It amplifies pain by activating fear circuits. Reducing it is a key treatment target." },
  { term: "Pain Neuroscience Education", def: "Teaching people how pain works. Shown to reduce pain, fear, and disability simply through understanding." },
  { term: "Pain Reprocessing Therapy (PRT)", def: "A treatment that retrains the brain to reinterpret pain as a false alarm rather than danger. Landmark trial: 66% pain-free in 4 weeks." },
  { term: "Phantom Limb Pain", def: "Pain felt in a limb that no longer exists. A powerful example of the brain generating pain without any body signal." },
  { term: "Somatic Tracking", def: "A technique of noticing pain sensations with curiosity rather than fear, reappraising them as safe." },
  { term: "Sensitization", def: "When your nervous system becomes more reactive over time. The opposite of habituation." },
];
---

<Base title="Glossary">
  <article class="container page-section">
    <h1>Glossary</h1>
    <p>Plain-language definitions of terms you'll encounter in neuroplastic pain research.</p>

    <div style="margin-top: 2rem;">
      {terms.map(({ term, def }) => (
        <div class="card" style="margin-bottom: 0.75rem;">
          <dt style="font-weight: 700; color: var(--teal-dark); margin-bottom: 0.2rem;">{term}</dt>
          <dd style="margin: 0; font-size: 0.95rem;">{def}</dd>
        </div>
      ))}
    </div>
  </article>
</Base>
