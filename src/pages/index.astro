---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const sorted = posts.sort((a, b) => b.data.date.localeCompare(a.data.date));
const latest = sorted.slice(0, 4);
const pubmedPosts = sorted.filter(p => p.data.tags?.includes('pubmed')).slice(0, 2);
const blogPosts = sorted.filter(p => p.data.tags?.includes('blog')).slice(0, 2);
---

<Base title="Home">
  <!-- Hero -->
  <section class="hero-gradient" style="
    color: white; padding: 5rem 0 4rem; position: relative; overflow: hidden;
  ">
    <div style="
      position: absolute; inset: 0; opacity: 0.08;
      background-image: radial-gradient(circle at 20% 50%, white 0%, transparent 50%),
                        radial-gradient(circle at 80% 80%, white 0%, transparent 40%);
    "></div>
    <div class="container" style="position: relative;">
      <p style="
        font-size: 0.85rem; opacity: 0.75; margin-bottom: 0.75rem;
        text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600;
      ">A research digest by Sunny Venkatesh</p>
      <h1 style="color: white; font-size: 2.8rem; max-width: 650px; margin-bottom: 1.25rem;">
        Your pain is real.<br />It can also change.
      </h1>
      <p style="font-size: 1.15rem; opacity: 0.9; max-width: 560px; margin-bottom: 2rem; line-height: 1.6;">
        Neuroplastic pain is a well-understood condition where your brain's pain pathways
        become hypersensitive — even after tissues heal. I simplify the latest research
        so you can understand what's happening and what actually helps.
      </p>
      <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
        <a href="/intro/what-is" class="btn" style="background: white; color: var(--teal); font-weight: 700;">
          Start here →
        </a>
        <a href="/quiz" class="btn" style="
          border: 2px solid rgba(255,255,255,0.4); color: white;
          background: rgba(255,255,255,0.1);
        ">
          Take the assessment
        </a>
      </div>
    </div>
  </section>

  <!-- Stats row -->
  <section class="container-wide" style="margin-top: -2rem; position: relative; z-index: 2;">
    <div style="
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;
      background: var(--warm-white); border-radius: var(--radius-lg);
      border: 1px solid var(--border); box-shadow: var(--shadow-md);
      padding: 1.5rem;
    ">
      {[
        { num: '66%', label: 'Pain-free after PRT (JAMA trial)' },
        { num: '100M+', label: 'Americans with chronic pain' },
        { num: '3', label: 'Pain types: nociceptive, neuropathic, nociplastic' },
      ].map((stat, i) => (
        <div class="fade-in" class:list={[`delay-${i+1}`]} style="text-align: center;">
          <div class="stat-number">{stat.num}</div>
          <div class="stat-label">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- How it works -->
  <section class="container page-section">
    <h2 style="text-align: center; margin-top: 0;">Understanding Neuroplastic Pain</h2>
    <p style="text-align: center; color: var(--text-muted); max-width: 500px; margin: 0.5rem auto 2.5rem;">
      Three things to know about this type of chronic pain.
    </p>
    <div style="
      display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.25rem;
    ">
      {[
        { icon: '🧠', title: 'It\'s Real', desc: 'Brain scans confirm the same pain regions activate as with acute injury. The cause differs, but the pain is identical.', color: '#0D7C66' },
        { icon: '📊', title: 'It\'s Common', desc: 'Fibromyalgia, chronic back pain, migraines, IBS, TMJ, pelvic pain — all involve central sensitization.', color: '#065A48' },
        { icon: '🔄', title: 'It Can Change', desc: 'Your brain wired the pain — and it can rewire it back. PRT shows 66% pain-free after 4 weeks in clinical trials.', color: '#0A4D3E' },
      ].map((item, i) => (
        <div class="card fade-in-up" class:list={[`delay-${i+1}`]} style="
          text-align: center; padding: 2rem 1.25rem;
          border-top: 3px solid {item.color};
        ">
          <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">{item.icon}</div>
          <h3 style="margin: 0 0 0.5rem; font-size: 1.1rem;">{item.title}</h3>
          <p style="font-size: 0.9rem; color: var(--text-muted); margin: 0; line-height: 1.6;">
            {item.desc}
          </p>
        </div>
      ))}
    </div>
  </section>

  <div class="container"><div class="section-divider" /></div>

  <!-- Latest Research -->
  <section class="container page-section">
    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem;">
      <div>
        <h2 style="margin: 0;">Latest Research</h2>
        <p style="color: var(--text-muted); margin: 0.25rem 0 0; font-size: 0.95rem;">
          Simplified summaries of recent papers and blog posts.
        </p>
      </div>
      <a href="/blog" class="btn btn-outline btn-sm">View all →</a>
    </div>

    {latest.length === 0 && (
      <div class="card" style="text-align: center; padding: 2.5rem 2rem;">
        <p style="font-size: 1.05rem; margin-bottom: 0.5rem;">No posts yet.</p>
        <p style="font-size: 0.9rem; color: var(--text-muted);">
          The pipeline runs weekly. Check back soon, or explore the <a href="/intro/what-is">intro guides</a>.
        </p>
      </div>
    )}

    <div style="display: flex; flex-direction: column; gap: 0.75rem;">
      {latest.map((post, i) => {
        const isBlog = post.data.tags?.includes('blog');
        const isResearch = post.data.tags?.includes('pubmed');
        return (
          <a href={`/blog/${post.id}`} style="text-decoration: none; color: inherit; display: block;">
            <article class="card card-flat" style="
              display: flex; align-items: center; gap: 1rem;
              padding: 1.1rem 1.25rem;
            ">
              <div style="
                width: 36px; height: 36px; border-radius: 8px;
                background: {isBlog ? '#E0E7FF' : 'var(--teal-light)'};
                display: flex; align-items: center; justify-content: center;
                flex-shrink: 0; font-size: 1rem;
              ">{isBlog ? '📝' : '📄'}</div>
              <div style="flex: 1; min-width: 0;">
                <div style="display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.15rem;">
                  {post.data.difficulty && (
                    <span class={`badge badge-${post.data.difficulty}`} style="font-size: 0.7rem;">
                      {post.data.difficulty}
                    </span>
                  )}
                  {isBlog && <span class="badge badge-blog" style="font-size: 0.7rem;">blog</span>}
                  {isResearch && <span class="badge badge-research" style="font-size: 0.7rem;">research</span>}
                </div>
                <span style="font-weight: 600; font-size: 0.95rem; line-height: 1.4;">
                  {post.data.title}
                </span>
                <div style="font-size: 0.78rem; color: var(--text-muted); margin-top: 0.15rem;">
                  {post.data.date} · {post.data.journal || 'Blog'}
                </div>
              </div>
              <span style="color: var(--text-light); font-size: 1.2rem; flex-shrink: 0;">→</span>
            </article>
          </a>
        );
      })}
    </div>
  </section>

  <div class="container"><div class="section-divider" /></div>

  <!-- About + CTA -->
  <section class="container page-section">
    <div class="card" style="
      padding: 2rem; display: flex; gap: 1.5rem;
      align-items: center; flex-wrap: wrap;
      background: linear-gradient(135deg, var(--teal-light), #F0FDFA);
      border-color: var(--teal-light);
    ">
      <div class="avatar" style="width: 64px; height: 64px; font-size: 1.6rem;">S</div>
      <div style="flex: 1; min-width: 240px;">
        <h3 style="margin: 0 0 0.3rem; font-size: 1.1rem;">Built by Sunny Venkatesh</h3>
        <p style="margin: 0; font-size: 0.9rem; color: var(--text-muted); line-height: 1.6;">
          I created Pain Rewired because the research on neuroplastic pain changed my understanding
          of chronic pain — and I wanted to make it accessible to everyone who needs it.
          I curate and simplify the latest findings so you don't have to read through
          dense academic papers.
        </p>
        <div style="margin-top: 0.75rem; display: flex; gap: 0.75rem; align-items: center;">
          <a href="/about" class="btn btn-primary btn-sm">More about me →</a>
          <a href="https://in.linkedin.com/in/sunny-venkatesh-877896194" target="_blank" rel="noopener noreferrer" class="btn btn-ghost btn-sm">
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA banner -->
  <section style="
    background: var(--teal-dark); color: white; padding: 3rem 0; text-align: center;
  ">
    <div class="container">
      <h2 style="color: white; margin: 0 0 0.75rem; font-size: 1.5rem;">
        Not sure where to start?
      </h2>
      <p style="opacity: 0.85; max-width: 440px; margin: 0 auto 1.5rem;">
        Take the self-assessment quiz to check if your symptoms match the neuroplastic pain pattern,
        or jump into the intro guides.
      </p>
      <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
        <a href="/quiz" class="btn" style="background: white; color: var(--teal-dark); font-weight: 700;">
          Take the quiz →
        </a>
        <a href="/intro/what-is" class="btn" style="border: 2px solid rgba(255,255,255,0.3); color: white;">
          Read the intro
        </a>
      </div>
    </div>
  </section>
</Base>
