---
import Base from '../layouts/Base.astro';
---

<Base title="Self-Assessment Quiz">
  <article class="container page-section">
    <h1>Self-Assessment Quiz</h1>

    <div class="card" style="background: #FFF8E1; border-left: 4px solid var(--accent); margin-bottom: 2rem;">
      <p style="margin: 0; font-size: 0.95rem;">
        <strong>Important:</strong> This is <em>not</em> a medical diagnosis. It is an educational tool 
        based on common patterns in central sensitization. Only a healthcare professional can diagnose 
        your condition. If you're in distress, please contact a doctor.
      </p>
    </div>

    <div id="quiz-app">
      <div id="question-screen">
        <div id="progress" style="margin-bottom: 1.5rem;">
          <div style="display: flex; justify-content: space-between; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.3rem;">
            <span id="q-number">Question 1 of 10</span>
            <span id="q-pct">0%</span>
          </div>
          <div style="background: var(--border); height: 6px; border-radius: 3px;">
            <div id="q-bar" style="background: var(--teal); height: 6px; border-radius: 3px; width: 0%; transition: width 0.3s;"></div>
          </div>
        </div>

        <div class="card" style="margin-bottom: 1.5rem;">
          <h3 id="q-text" style="margin: 0 0 1.5rem;">Loading...</h3>
          <div id="q-options" style="display: flex; flex-direction: column; gap: 0.5rem;"></div>
        </div>

        <div style="display: flex; gap: 1rem;">
          <button id="btn-prev" class="btn btn-outline" style="display: none;">← Back</button>
          <button id="btn-next" class="btn btn-primary" disabled>Next →</button>
        </div>
      </div>

      <div id="result-screen" style="display: none;">
        <div class="card" style="margin-bottom: 1rem;">
          <h2 style="margin-top: 0;">Your Results</h2>
          <p style="font-size: 1.1rem; margin-bottom: 0.5rem;">Score: <strong id="r-score">0</strong>/40</p>
          <p style="font-size: 1.1rem;">Range: <strong id="r-range">-</strong></p>
        </div>

        <div id="r-interpretation" class="card" style="margin-bottom: 1rem;"></div>

        <div class="card" style="background: var(--teal-light);">
          <p style="margin: 0; font-size: 0.95rem;">
            <strong>What now?</strong> This is a starting point for awareness, not a verdict. 
            If your score suggests central sensitization may be involved, consider:
          </p>
          <ul style="margin-top: 0.5rem; margin-bottom: 0;">
            <li>Reading the <a href="/intro/what-is">intro guides</a> on this site</li>
            <li>Discussing central sensitization with your doctor</li>
            <li>Exploring <a href="/intro/treatments">evidence-based treatments</a></li>
            <li>Looking into Pain Reprocessing Therapy resources</li>
          </ul>
        </div>

        <div style="margin-top: 1.5rem; display: flex; gap: 1rem; flex-wrap: wrap;">
          <button id="btn-restart" class="btn btn-primary">Restart quiz</button>
          <a href="/intro/what-is" class="btn btn-outline">Start the intro guides</a>
        </div>
      </div>
    </div>
  </article>
</Base>

<script>
const questions = [
  { text: "Do you have pain in multiple areas of your body that shifts location?", options: [
    { label: "Never", value: 0 },
    { label: "Rarely", value: 1 },
    { label: "Sometimes", value: 2 },
    { label: "Often", value: 3 },
    { label: "Always", value: 4 },
  ]},
  { text: "Do things that shouldn't hurt cause pain — like light touch, clothing, or being hugged?", options: [
    { label: "Never", value: 0 },
    { label: "Rarely", value: 1 },
    { label: "Sometimes", value: 2 },
    { label: "Often", value: 3 },
    { label: "Always", value: 4 },
  ]},
  { text: "Do you feel exhausted even after a full night's sleep?", options: [
    { label: "Never", value: 0 },
    { label: "Rarely", value: 1 },
    { label: "Sometimes", value: 2 },
    { label: "Often", value: 3 },
    { label: "Always", value: 4 },
  ]},
  { text: "Are you sensitive to bright lights, loud noises, or strong smells?", options: [
    { label: "Never", value: 0 },
    { label: "Rarely", value: 1 },
    { label: "Sometimes", value: 2 },
    { label: "Often", value: 3 },
    { label: "Always", value: 4 },
  ]},
  { text: "Does stress or emotional upset make your pain significantly worse?", options: [
    { label: "Never", value: 0 },
    { label: "Rarely", value: 1 },
    { label: "Sometimes", value: 2 },
    { label: "Often", value: 3 },
    { label: "Always", value: 4 },
  ]},
  { text: "Do you experience brain fog — trouble concentrating, remembering, or thinking clearly?", options: [
    { label: "Never", value: 0 },
    { label: "Rarely", value: 1 },
    { label: "Sometimes", value: 2 },
    { label: "Often", value: 3 },
    { label: "Always", value: 4 },
  ]},
  { text: "Have medical tests (X-rays, MRIs, blood work) come back normal despite your pain?", options: [
    { label: "Not applicable / haven't tested", value: 0 },
    { label: "Yes, but I still have pain", value: 3 },
    { label: "Minor findings that don't explain the pain", value: 2 },
    { label: "Tests found a clear cause", value: 0 },
  ]},
  { text: "Do you have multiple conditions from this list? (fibromyalgia, IBS, migraines, TMJ, chronic back pain, pelvic pain, restless legs, interstitial cystitis, chronic fatigue)", options: [
    { label: "None", value: 0 },
    { label: "1 condition", value: 1 },
    { label: "2 conditions", value: 2 },
    { label: "3 conditions", value: 3 },
    { label: "4 or more", value: 4 },
  ]},
  { text: "Does physical activity trigger pain flare-ups that last for hours or days?", options: [
    { label: "Never", value: 0 },
    { label: "Rarely", value: 1 },
    { label: "Sometimes", value: 2 },
    { label: "Often", value: 3 },
    { label: "Always", value: 4 },
  ]},
  { text: "Have treatments targeting the body (surgery, injections, physical therapy, chiropractic) failed to help or made pain worse?", options: [
    { label: "Never tried them", value: 0 },
    { label: "They helped significantly", value: 0 },
    { label: "Helped a little but pain returned", value: 2 },
    { label: "No improvement", value: 3 },
    { label: "Made things worse", value: 4 },
  ]},
];

let current = 0;
const answers = new Array(questions.length).fill(null);

const qNumber = document.getElementById('q-number');
const qPct = document.getElementById('q-pct');
const qBar = document.getElementById('q-bar');
const qText = document.getElementById('q-text');
const qOptions = document.getElementById('q-options');
const btnPrev = document.getElementById('btn-prev');
const btnNext = document.getElementById('btn-next');
const questionScreen = document.getElementById('question-screen');
const resultScreen = document.getElementById('result-screen');
const rScore = document.getElementById('r-score');
const rRange = document.getElementById('r-range');
const rInterpretation = document.getElementById('r-interpretation');
const btnRestart = document.getElementById('btn-restart');

function render() {
  const q = questions[current];
  qNumber.textContent = `Question ${current + 1} of ${questions.length}`;
  const pct = Math.round(((current + 1) / questions.length) * 100);
  qPct.textContent = `${pct}%`;
  qBar.style.width = `${pct}%`;
  qText.textContent = q.text;
  qOptions.innerHTML = '';
  q.options.forEach((opt, i) => {
    const label = document.createElement('label');
    label.style.cssText = `
      display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem;
      border: 2px solid var(--border); border-radius: 8px; cursor: pointer;
      transition: all 0.15s;
    `;
    if (answers[current] === i) {
      label.style.borderColor = 'var(--teal)';
      label.style.background = 'var(--teal-light)';
    }
    const radio = document.createElement('input');
    radio.type = 'radio';
    radio.name = 'question';
    radio.value = i;
    radio.checked = answers[current] === i;
    radio.addEventListener('change', () => select(i));
    const text = document.createTextNode(opt.label);
    label.prepend(radio);
    label.append(text);
    qOptions.appendChild(label);
  });
  btnPrev.style.display = current === 0 ? 'none' : 'inline-flex';
  btnNext.disabled = answers[current] === null;
  btnNext.textContent = current === questions.length - 1 ? 'See results →' : 'Next →';
}

function select(i) {
  answers[current] = i;
  render();
  if (current < questions.length - 1) {
    btnNext.disabled = false;
  }
}

btnNext.addEventListener('click', () => {
  if (answers[current] === null) return;
  if (current === questions.length - 1) {
    showResults();
  } else {
    current++;
    render();
  }
});

btnPrev.addEventListener('click', () => {
  if (current > 0) {
    current--;
    render();
  }
});

btnRestart.addEventListener('click', () => {
  answers.fill(null);
  current = 0;
  questionScreen.style.display = 'block';
  resultScreen.style.display = 'none';
  render();
});

function showResults() {
  const total = answers.reduce((sum, i) => sum + questions[current].options[i].value, 0);
  // Recalculate properly
  let sum = 0;
  for (let i = 0; i < questions.length; i++) {
    if (answers[i] !== null) {
      sum += questions[i].options[answers[i]].value;
    }
  }
  rScore.textContent = sum;

  let range, interpretation;
  if (sum <= 10) {
    range = 'Low (0–10) — Minimal indicators';
    interpretation = `
      <p>Your responses suggest fewer indicators of central sensitization. This doesn't mean your pain 
      isn't real — it may have a different mechanism (nociceptive or neuropathic), or it may simply 
      not fit the neuroplastic pattern strongly.</p>
      <p>If you're in pain, it's still worth discussing with a healthcare provider and exploring 
      all possible causes.</p>
    `;
  } else if (sum <= 20) {
    range = 'Mild (11–20) — Some indicators present';
    interpretation = `
      <p>You have some features consistent with central sensitization. This is a moderate signal — 
      worth exploring further but not definitive.</p>
      <p>Consider reading the intro guides and speaking with a clinician about whether 
      central sensitization might be part of your picture.</p>
    `;
  } else if (sum <= 30) {
    range = 'Moderate (21–30) — Significant indicators';
    interpretation = `
      <p>Your responses show a significant pattern of central sensitization features. This suggests 
      that neuroplastic mechanisms may be playing an important role in your pain.</p>
      <p>Many people in this range find brain-based treatments (PRT, EAET, pain education) very helpful. 
      Consider exploring these approaches with a qualified practitioner.</p>
    `;
  } else {
    range = 'High (31–40) — Strong indicators';
    interpretation = `
      <p>Your responses indicate a strong pattern consistent with central sensitization. This is a 
      common presentation in conditions like fibromyalgia, chronic widespread pain, and other 
      central sensitization syndromes.</p>
      <p>This is a well-studied and treatable condition. Brain-based approaches have strong evidence 
      for this range. Please discuss with a healthcare professional who understands neuroplastic pain.</p>
    `;
  }

  rRange.textContent = range;
  rInterpretation.innerHTML = interpretation;

  questionScreen.style.display = 'none';
  resultScreen.style.display = 'block';
}

render();
</script>
