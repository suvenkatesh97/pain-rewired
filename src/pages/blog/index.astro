---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const sorted = posts.sort((a, b) => b.data.date.localeCompare(a.data.date));

const allTags = [...new Set(sorted.flatMap(p => p.data.tags || []))].sort();
const pubmedCount = sorted.filter(p => p.data.tags?.includes('pubmed')).length;
const blogCount = sorted.filter(p => p.data.tags?.includes('blog')).length;
---

<Base title="Research Digest">
  <section class="hero-gradient-light page-section" style="padding: 3rem 0;">
    <div class="container">
      <p style="font-size: 0.85rem; color: var(--teal); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; margin-bottom: 0.5rem;">Research Digest</p>
      <h1 style="margin: 0 0 0.75rem;">Latest Research & Articles</h1>
      <p style="color: var(--text-muted); max-width: 520px; margin: 0;">
        Simplified summaries of peer-reviewed papers and expert blog posts on neuroplastic pain,
        central sensitization, and brain-based treatments.
      </p>
      <div style="display: flex; gap: 1.5rem; margin-top: 1.25rem; flex-wrap: wrap;">
        <div><span class="badge badge-research">{pubmedCount}</span>
        <span style="font-size: 0.85rem; color: var(--text-muted); margin-left: 0.4rem;">Research papers</span></div>
        <div><span class="badge badge-blog">{blogCount}</span>
        <span style="font-size: 0.85rem; color: var(--text-muted); margin-left: 0.4rem;">Blog posts</span></div>
        <div><span class="badge badge-beginner">{sorted.length}</span>
        <span style="font-size: 0.85rem; color: var(--text-muted); margin-left: 0.4rem;">Total posts</span></div>
      </div>
    </div>
  </section>

  <section class="container page-section" style="padding-top: 2rem;">
    {sorted.length === 0 && (
      <div class="card" style="text-align: center; padding: 2.5rem;">
        <p style="font-size: 1.1rem; margin-bottom: 0.5rem;">No posts yet.</p>
        <p style="color: var(--text-muted);">The first batch will arrive soon. Check back later.</p>
        <a href="/intro/what-is" class="btn btn-primary" style="margin-top: 1rem;">Start with the intro →</a>
      </div>
    )}

    {sorted.length > 0 && (
      <div style="display: flex; flex-direction: column; gap: 0.75rem;">
        {sorted.map((post, i) => {
          const isBlog = post.data.tags?.includes('blog');
          const isResearch = post.data.tags?.includes('pubmed');
          return (
            <a href={`/blog/${post.id}`} style="text-decoration: none; color: inherit; display: block;">
              <article class="card card-flat fade-in-up" class:list={[i < 3 ? `delay-${i+1}` : '']} style="
                display: flex; align-items: center; gap: 1rem; padding: 1.1rem 1.25rem;
              ">
                <div style="
                  width: 40px; height: 40px; border-radius: 10px;
                  background: {isBlog ? '#E0E7FF' : 'var(--teal-light)'};
                  display: flex; align-items: center; justify-content: center;
                  flex-shrink: 0; font-size: 1.1rem;
                ">{isBlog ? '📝' : '📄'}</div>
                <div style="flex: 1; min-width: 0;">
                  <div style="display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.15rem;">
                    {post.data.difficulty && (
                      <span class={`badge badge-${post.data.difficulty}`} style="font-size: 0.7rem;">
                        {post.data.difficulty}
                      </span>
                    )}
                    {isBlog && <span class="badge badge-blog" style="font-size: 0.7rem;">blog</span>}
                    {isResearch && <span class="badge badge-research" style="font-size: 0.7rem;">research</span>}
                    {post.data.tags?.filter(t => t !== 'blog' && t !== 'pubmed' && t !== 'opinion').slice(0, 2).map(t => (
                      <span class="tag" style="font-size: 0.7rem;">{t}</span>
                    ))}
                  </div>
                  <span style="font-weight: 600; font-size: 0.95rem; line-height: 1.4;">
                    {post.data.title}
                  </span>
                  <div style="font-size: 0.78rem; color: var(--text-muted); margin-top: 0.15rem;">
                    {post.data.date}
                    {post.data.journal ? ` · ${post.data.journal}` : ''}
                  </div>
                </div>
                <span style="color: var(--text-light); font-size: 1.2rem; flex-shrink: 0;">→</span>
              </article>
            </a>
          );
        })}
      </div>
    )}
  </section>
</Base>
